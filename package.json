{
  "name": "biassemble-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --watch --import tsx src/server.ts",
    "build": "rimraf dist && esbuild api/handler.ts --bundle --platform=node --format=esm --packages=external --outfile=api/index.js && cp -r evaluations api/evaluations",
    "start": "node --env-file=.env dist/server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "eval": "tsx --env-file=.env scripts/eval-reflection.ts",
    "eval:trigger": "tsx --env-file=.env scripts/trigger-eval.ts",
    "eval:trigger:golden": "tsx --env-file=.env scripts/trigger-eval-golden.ts",
    "eval:trigger:no-bias": "tsx --env-file=.env scripts/trigger-eval-no-bias.ts",
    "generate:contracts": "tsx scripts/generate-contracts.ts",
    "deploy": "vercel deploy --prod && pnpm run inngest:sync",
    "inngest:sync": "curl -s -o /dev/null -w '%{http_code}' https://biassemble-core.vercel.app/api/inngest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@google/generative-ai": "0.21.0",
    "drizzle-orm": "0.38.4",
    "fastify": "5.8.5",
    "inngest": "3.54.2",
    "pino": "9.14.0",
    "pino-pretty": "13.1.3",
    "postgres": "3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "drizzle-kit": "0.30.6",
    "esbuild": "0.28.0",
    "rimraf": "6.1.3",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}