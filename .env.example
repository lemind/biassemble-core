# AI Provider
GEMINI_API_KEY=your-google-ai-studio-key
GEMINI_MODEL=gemini-2.0-flash

# Core Authentication
AI_CORE_API_KEY=dev-secret-change-me

# Server
PORT=3001

# AI Configuration
AI_TIMEOUT_MS=10000
AI_MAX_RETRIES=3

# Inngest (production only — tells Inngest Cloud where to reach this app)
INNGEST_SERVE_HOST=https://biassemble-core.vercel.app

# Vercel deployment protection bypass (for Inngest callback)
# Create a bypass token in Vercel Dashboard → Settings → Deployment Protection → Protection Bypass for Automation
VERCEL_BYPASS_TOKEN=

# Logging
LOG_LEVEL=info
