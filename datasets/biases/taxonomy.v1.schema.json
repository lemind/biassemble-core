{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://biassemble.internal/schemas/bias-taxonomy.v1.json",
  "title": "Biassemble bias taxonomy v1",
  "type": "object",
  "required": ["version", "biases"],
  "properties": {
    "version": { "type": "string", "const": "1.0.0" },
    "biases": {
      "type": "array",
      "items": { "$ref": "#/$defs/biasEntry" },
      "minItems": 1
    }
  },
  "$defs": {
    "biasEntry": {
      "type": "object",
      "required": ["id", "name", "category", "definition", "mvpPriority"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "Stable slug, never renamed"
        },
        "name": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "definition": { "type": "string", "minLength": 10 },
        "detectionSignals": {
          "type": "array",
          "items": { "type": "string" }
        },
        "relatedIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mvpPriority": {
          "type": "string",
          "enum": ["tier-a", "tier-b", "tier-c"],
          "description": "tier-a: prompt shortlist; tier-b: catalog only; tier-c: RAG later"
        }
      },
      "additionalProperties": false
    }
  }
}
